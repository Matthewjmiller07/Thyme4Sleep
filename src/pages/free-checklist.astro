---
import Layout from '../layouts/LayoutNoConsent.astro';

const pageTitle = 'Free Essential Sleep Checklist | Thyme4Sleep';
const pageDescription = 'Download your free Essential Sleep Checklist - everything you need to create the perfect sleep environment for your little one.';
---

<Layout title={pageTitle} description={pageDescription}>
  <script>
    // Handle form submission
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('lead-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const formSection = document.getElementById('form-section');
      const successSection = document.getElementById('success-section');
      
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          if (!submitBtn || !formSection || !successSection) return;
          
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
          
          const formData = new FormData(form);
          
          try {
            const response = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              body: formData
            });
            
            const data = await response.json();
            
            if (data.success) {
              // Hide form, show success message with download link
              formSection.classList.add('hidden');
              successSection.classList.remove('hidden');
              
              // Scroll to success section
              successSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } else {
              throw new Error(data.message || 'Submission failed');
            }
          } catch (error) {
            console.error('Form submission error:', error);
            alert('Something went wrong. Please try again or email georgia@thyme4sleep.com');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Get My Free Checklist';
          }
        });
      }
    });
  </script>

  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-brandMint/20 to-brandCream overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url(\"data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-.895-3-2-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-.895-3-2-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-.895-3-2-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-.895-3-2-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29-22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%233F3B38' fill-opacity='0.1' fill-rule='evenodd'/%3E%3C/svg%3E\")"></div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block bg-brandPeach/30 text-brandTaupe text-sm font-bold tracking-widest uppercase px-4 py-2 rounded-full mb-6">
          Free Download
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-light text-brandChar mb-6">
          Your <span class="font-medium">Essential Sleep Checklist</span>
        </h1>
        <div class="h-1 w-24 bg-accent mx-auto mb-6"></div>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed mb-8">
          Everything you need to create the perfect sleep environment for your little one. Download this free checklist and start improving sleep tonight.
        </p>
        
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-gray-600">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-brandSage mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            100% Free
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-brandSage mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            Instant Download
          </div>
          <div class="flex items-center">
            <svg class="w-5 h-5 text-brandSage mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            No Credit Card
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Inside Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-light text-brandChar mb-4">What's Inside Your Checklist</h2>
        <div class="h-1 w-16 bg-accent mx-auto"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="bg-brandCream rounded-2xl p-8 shadow-sm border border-brandPeach/20">
          <div class="w-12 h-12 bg-brandPeach/30 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brandTaupe" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-medium text-brandChar mb-3">Sleep Environment Essentials</h3>
          <p class="text-gray-600 leading-relaxed">The exact room setup, temperature, lighting, and sound conditions for optimal sleep.</p>
        </div>

        <div class="bg-brandCream rounded-2xl p-8 shadow-sm border border-brandPeach/20">
          <div class="w-12 h-12 bg-brandMint/30 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brandSage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-medium text-brandChar mb-3">Bedtime Routine Steps</h3>
          <p class="text-gray-600 leading-relaxed">A simple, proven routine that signals to your baby it's time to wind down and sleep.</p>
        </div>

        <div class="bg-brandCream rounded-2xl p-8 shadow-sm border border-brandPeach/20">
          <div class="w-12 h-12 bg-brandSage/20 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brandSage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-xl font-medium text-brandChar mb-3">Safety Checklist</h3>
          <p class="text-gray-600 leading-relaxed">Critical safety items to ensure your baby's sleep space is secure and risk-free.</p>
        </div>

        <div class="bg-brandCream rounded-2xl p-8 shadow-sm border border-brandPeach/20">
          <div class="w-12 h-12 bg-accent/20 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-medium text-brandChar mb-3">Quick Wins</h3>
          <p class="text-gray-600 leading-relaxed">Simple changes you can make today that will have an immediate positive impact on sleep.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section id="form-section" class="py-16 bg-brandCream">
    <div class="container mx-auto px-6 max-w-2xl">
      <div class="bg-white rounded-3xl p-10 md:p-14 shadow-xl">
        <div class="text-center mb-8">
          <div class="w-16 h-16 bg-brandPeach/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brandTaupe" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-3xl font-light text-brandChar mb-3">Get Your Free Checklist</h2>
          <p class="text-gray-600">Enter your details below for instant access</p>
        </div>

        <form id="lead-form" class="space-y-6">
          <!-- Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="446b9501-1418-4401-b080-b126515a1304">
          <input type="hidden" name="subject" value="New Essential Checklist Download">
          <input type="hidden" name="from_name" value="Thyme4Sleep Lead Magnet">
          
          <!-- Honeypot for spam protection -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div>
            <label for="name" class="block text-sm font-medium text-brandChar mb-2">Your Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandSage focus:border-transparent transition-all"
              placeholder="Jane Smith"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-brandChar mb-2">Email Address *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandSage focus:border-transparent transition-all"
              placeholder="jane@example.com"
            />
          </div>

          <div>
            <label class="flex items-start">
              <input
                type="checkbox"
                name="consent"
                required
                class="mt-1 mr-3 h-4 w-4 text-brandSage focus:ring-brandSage border-gray-300 rounded"
              />
              <span class="text-sm text-gray-600">
                I agree to receive helpful sleep tips and updates from Thyme4Sleep. You can unsubscribe anytime.
              </span>
            </label>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full px-8 py-4 text-lg font-bold bg-brandSage hover:bg-brandMink text-white rounded-full transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg"
          >
            Get My Free Checklist
          </button>

          <p class="text-xs text-center text-gray-500">
            We respect your privacy. Your information will never be shared.
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Success Section (Hidden by default) -->
  <section id="success-section" class="hidden py-16 bg-brandCream">
    <div class="container mx-auto px-6 max-w-2xl">
      <div class="bg-white rounded-3xl p-10 md:p-14 shadow-xl text-center">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        
        <h2 class="text-3xl font-light text-brandChar mb-4">Check Your Email!</h2>
        <p class="text-lg text-gray-600 mb-8">
          Your Essential Sleep Checklist is on its way to your inbox. In the meantime, you can download it right now:
        </p>

        <a
          href="/essential-checklist.pdf"
          download
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold bg-brandPeach hover:bg-brandTaupe text-brandChar hover:text-white rounded-full transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg mb-8"
        >
          <svg class="w-6 h-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Download Your Checklist
        </a>

        <div class="border-t border-gray-200 pt-8 mt-8">
          <h3 class="text-xl font-medium text-brandChar mb-4">Want More Support?</h3>
          <p class="text-gray-600 mb-6">
            Ready to dive deeper? Get the complete Reset to Rest guide with video walkthrough for just $37.
          </p>
          <a
            href="/reset-preview"
            class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-brandSage hover:bg-brandMink text-white rounded-full transition-all duration-300"
          >
            Learn More About Reset to Rest
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
